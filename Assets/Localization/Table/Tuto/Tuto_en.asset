  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Tuto_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 0edc49eb3e109a1488bebf846b3cd54e, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 4829941760
    m_Localized: 'During a fight, the goal is to parry the opponent''s attacks.

      Observe
      their movements to determine the direction of the attack.'
    m_Metadata:
      m_Items: []
  - m_Id: 20130762752
    m_Localized: 'To parry an attack, swipe your finger across the screen in the
      opposite direction.

      So, if an enemy attacks from right to left, swipe
      your finger from left to right to parry.'
    m_Metadata:
      m_Items: []
  - m_Id: 32277467136
    m_Localized: 'If you manage to parry an attack from your opponent, you inflict
      damage on them.

      Conversely, if you fail, you are the one who will be
      injured.

      You win when your opponent has no more health, and you lose
      when you have no more health.'
    m_Metadata:
      m_Items: []
  - m_Id: 38384373760
    m_Localized: 'Timing your parries is crucial. Release your finger from the screen
      to initiate the parry.

      If you parry at the right moment (while your
      opponent is swinging their weapon), you''ll perform a perfect parry!

      A
      perfect parry deals more damage.'
    m_Metadata:
      m_Items: []
  - m_Id: 53718749184
    m_Localized: 'Opponents use combos: a series of successive attacks followed by
      a pause.

      Parry all attacks in a combo to inflict significant damage.
      It''s the fastest way to win!'
    m_Metadata:
      m_Items: []
  - m_Id: 2144678768218112
    m_Localized: Fighting
    m_Metadata:
      m_Items: []
  - m_Id: 2144989914271744
    m_Localized: Roguelite
    m_Metadata:
      m_Items: []
  - m_Id: 2146616364699648
    m_Localized: 'Between each fight, you''ll return to the level selection screen.
      This is where you can manage your progress.

      The bar at the top of the
      screen shows you the number of fights you''ve won compared to your total.'
    m_Metadata:
      m_Items: []
  - m_Id: 2148256404672512
    m_Localized: 'After each battle, you can choose one of three upgrades.

      These
      upgrades will make you stronger and easier in future battles. Read the descriptions
      carefully and choose the one you want.'
    m_Metadata:
      m_Items: []
  - m_Id: 2148961781747712
    m_Localized: You can view the improvements you have selected in the pause menu
      by pressing the button in the top right corner of the screen.
    m_Metadata:
      m_Items: []
  - m_Id: 2150081400868864
    m_Localized: 'Once you''ve chosen an upgrade, you''ll need to select your next
      battle.

      The three options vary in difficulty. Click on a level for
      more details.'
    m_Metadata:
      m_Items: []
  - m_Id: 2151011689107456
    m_Localized: 'A tougher fight means better rewards.

      Once you''ve made
      your choice, press the button to start the fight.'
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
